# .env.prod.example — copy to .env.prod and fill in all values
# DO NOT commit .env.prod to git

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=CHANGE_ME
INFLUXDB_TOKEN=CHANGE_ME
INFLUXDB_ORG=coaching
INFLUXDB_BUCKET=training

# PostgreSQL
POSTGRES_USER=coaching
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=coaching_db

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# Config UI API key (any strong random string)
CONFIG_API_KEY=CHANGE_ME

# CORS — comma-separated allowed origins for the Config UI
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Ollama
OLLAMA_PRIMARY_URL=http://192.168.50.46:11434
OLLAMA_FALLBACK_URL=
OLLAMA_HEAVY_MODEL=qwen2.5:72b
OLLAMA_FAST_MODEL=qwen2.5:14b

# Garmin Connect credentials (for data sync)
GARMIN_USERNAME=CHANGE_ME
GARMIN_PASSWORD=CHANGE_ME

# GHCR token — needed for Watchtower to pull private images
# Create at: GitHub → Settings → Developer settings → Personal access tokens
# Scopes: read:packages
GHCR_USER=sasharif87
GHCR_TOKEN=CHANGE_ME

# ntfy push notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=CHANGE_ME
NTFY_TOKEN=

# TrueNAS host IP (used in deploy.sh output URLs)
TRUENAS_IP=192.168.50.X

# TrueNAS data root (used by preflight.sh)
COACHING_DATA_ROOT=/mnt/tank/coaching

# Timezone
TZ=America/Toronto
