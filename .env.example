# AI Coaching System — Environment Variables
# Copy to .env and fill in your values before deploying
# Never commit .env to git

# ---------------------------------------------------------------------------
# Ollama (external — running on TrueNAS or dedicated machine)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://192.168.50.46:11434
OLLAMA_MODEL=llama3.1:70b

# ---------------------------------------------------------------------------
# InfluxDB 2.x
# Generate a strong random token: openssl rand -hex 32
# ---------------------------------------------------------------------------
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_ORG=coaching
INFLUXDB_BUCKET=training
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me-strong-password

# ---------------------------------------------------------------------------
# Garmin Connect (for garmindb sync + garth workout push)
# ---------------------------------------------------------------------------
GARMIN_USERNAME=your@email.com
GARMIN_PASSWORD=your-garmin-password

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-strong-password

# ---------------------------------------------------------------------------
# Path config (defaults work with Docker volumes; override for bind mounts)
# ---------------------------------------------------------------------------
GARMIN_DATA_DIR=/data/garmin
GARTH_HOME=/data/garth
ZWIFT_WORKOUTS_DIR=/data/zwift_workouts
LOG_DIR=/data/logs

# ---------------------------------------------------------------------------
# Pipeline behaviour
# ---------------------------------------------------------------------------
# Cron schedule for daily pipeline (default: 3 AM)
PIPELINE_CRON=0 3 * * *

# Timezone for scheduler
TZ=Australia/Melbourne

# Number of days of history to load for CTL/ATL (Banister model needs 90+)
CTL_LOOKBACK_DAYS=120

# RAG: how many similar historical blocks to inject into LLM context
RAG_RESULTS=3

# LLM request timeout in seconds (70B overnight batch can be slow)
LLM_TIMEOUT=300

# ---------------------------------------------------------------------------
# PostgreSQL (structured plan/actual store)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://coaching:your-password@postgres:5432/coaching
# Or use individual vars:
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=coaching
# POSTGRES_USER=coaching
# POSTGRES_PASSWORD=your-password

# ---------------------------------------------------------------------------
# Season config & workout library paths
# ---------------------------------------------------------------------------
SEASON_CONFIG_PATH=/config/season.json
WORKOUTS_CONFIG_DIR=/config/workouts
WORKOUT_IMPORT_DIR=/config/workouts/imports

# Race calendar markdown export path
RACE_CALENDAR_MD=/data/race_calendar.md

# ---------------------------------------------------------------------------
# Notifications (ntfy.sh + optional email)
# ---------------------------------------------------------------------------
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=training-coach

# SMTP (optional — leave blank to disable email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=coach@yourdomain.com
# NOTIFICATION_EMAIL=your@email.com

# ---------------------------------------------------------------------------
# Weather (Open-Meteo — free, no API key needed)
# Default location for weather-aware scheduling
# ---------------------------------------------------------------------------
ATHLETE_LATITUDE=39.7392
ATHLETE_LONGITUDE=-104.9903

# ---------------------------------------------------------------------------
# TrainingPeaks (optional — for planned workout import)
# ---------------------------------------------------------------------------
# TRAININGPEAKS_ACCESS_TOKEN=your-token-here
